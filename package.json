{
    "name": "@plurnk/plurnk-mimetypes-text-swift",
    "version": "0.2.1",
    "description": "text/x-swift mimetype handler for plurnk-service. Tier 2: tree-sitter-swift grammar built to WASM and shipped pre-built in this package. Covers Swift 6 features (macros, parameter packs, typed throws, noncopyable types, ownership modifiers).",
    "type": "module",
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    },
    "engines": {
        "node": ">=26"
    },
    "plurnk": {
        "kind": "mimetype",
        "handlers": [
            {
                "name": "text/x-swift",
                "glyph": "🦅",
                "extensions": [
                    ".swift"
                ]
            }
        ]
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json",
        "./swift.wasm": "./swift.wasm"
    },
    "files": [
        "dist/**/*",
        "swift.wasm",
        ".swift-grammar-pin",
        "README.md"
    ],
    "scripts": {
        "build:wasm": "node scripts/build-wasm.mjs",
        "build:dist": "tsc -p tsconfig.build.json",
        "build": "npm run build:dist",
        "test:lint": "tsc --noEmit",
        "test:unit": "node --test src/**/*.test.ts",
        "test": "npm run test:lint && npm run test:unit",
        "prepare": "npm run build",
        "verify:wasm": "node scripts/verify-wasm.mjs"
    },
    "dependencies": {
        "web-tree-sitter": "^0.26.9"
    },
    "devDependencies": {
        "@plurnk/plurnk-mimetypes": "^0.15.34",
        "@types/node": "^26.0.0",
        "tree-sitter-cli": "^0.26.9",
        "typescript": "^6.0.3"
    },
    "peerDependencies": {
        "@plurnk/plurnk-mimetypes": "^0.15.19"
    }
}
